# AI provider
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-5.4
OPENAI_REASONING_EFFORT=xhigh

# Backend access and optional Codex runtime
ASTERIA_CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
ASTERIA_CODEX_RUNTIME_ENABLED=false
ASTERIA_ENABLE_CODEX_RUNTIME_API=false
# These privileged capabilities are disabled by default and require explicit operator opt-in.
# Unsandboxed Codex execution also requires a matching runtime request or persisted setting.
ASTERIA_ALLOW_UNSANDBOXED_CODEX_RUNTIME=false
# Enables local lab skill/team imports, mounts, and executions only when explicitly enabled.
ASTERIA_ENABLE_LOCAL_SKILL_INSTALLER=false
ASTERIA_CODEX_SEARCH_ENABLED=false
ASTERIA_CODEX_TIMEOUT_SEC=1800
ASTERIA_CODEX_USE_LOGIN_AUTH=true

# Frontend API endpoint
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000
